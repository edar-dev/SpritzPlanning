{
  "name": "SpritzPlanning",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "FLUTTER_VERSION": "3.35.6"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "Dart-Code.dart-code",
        "Dart-Code.flutter"
      ],
      "settings": {
        "dart.flutterSdkPath": "/opt/flutter"
      }
    }
  },
  "forwardPorts": [8080],
  "postCreateCommand": "bash scripts/dev-setup.sh",
  "remoteUser": "root"
}
