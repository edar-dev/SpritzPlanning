{
  "buildCommand": "bash scripts/vercel-build.sh",
  "ignoreCommand": "bash scripts/vercel-should-build.sh",
  "outputDirectory": "build/web",
  "framework": null,
  "installCommand": "echo 'Dependencies installed in build script'",
  "redirects": [
    {
      "source": "/help",
      "destination": "/app/help",
      "permanent": true
    },
    {
      "source": "/room/:path*",
      "destination": "/app/room/:path*",
      "permanent": true
    },
    {
      "source": "/auth/callback",
      "destination": "/app/auth/callback",
      "permanent": true
    },
    {
      "source": "/invite/:token",
      "destination": "/app/invite/:token",
      "permanent": true
    },
    {
      "source": "/ops/health",
      "destination": "/app/ops/health",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/j/:code",
      "destination": "/join.html?code=:code"
    },
    {
      "source": "/en",
      "destination": "/landing-en.html"
    },
    {
      "source": "/features",
      "destination": "/features.html"
    },
    {
      "source": "/en/features",
      "destination": "/features-en.html"
    },
    {
      "source": "/faq",
      "destination": "/faq.html"
    },
    {
      "source": "/en/faq",
      "destination": "/faq-en.html"
    },
    {
      "source": "/app",
      "destination": "/app/index.html"
    },
    {
      "source": "/app/",
      "destination": "/app/index.html"
    },
    {
      "source": "/app/:path((?!.*\\..*).*)",
      "destination": "/app/index.html"
    }
  ],
  "headers": [
    {
      "source": "/app/manifest.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    },
    {
      "source": "/app/canvaskit/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/app/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/app/room/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    },
    {
      "source": "/app/ops/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    },
    {
      "source": "/app/auth/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    },
    {
      "source": "/app/invite/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    }
  ]
}
